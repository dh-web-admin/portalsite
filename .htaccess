RewriteEngine On

# Redirect to HTTPS (Railway provides SSL)
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ✅ Never route uploads through the app
RewriteRule ^(PortalSite/)?uploads/ - [L]

# ✅ Map public /uploads/* to mounted volume folder
RewriteRule ^uploads/(.*)$ /portalsite/uploads/$1 [L,PT]
RewriteRule ^PortalSite/uploads/(.*)$ /portalsite/uploads/$1 [L,PT]

# Don't rewrite files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Security: Block access to sensitive files
<FilesMatch "^(config\.php|\.git|\.env)">
    Order allow,deny
    Deny from all
</FilesMatch>

ErrorDocument 404 /index.php
ErrorDocument 500 /index.php

Options -Indexes

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>
